// Forever System — Prisma schema.
// Slice 0 establishes the User. Slice 1 adds the Goal (held in the Vault).
// Slice 2 adds the Task (carrying a Gear). Slice 3 adds rank for Active Goals.
// Slice 4 adds Pulse, Assignment, and AssignmentItem (snapshot of Tasks at Pulse time).
// Slice 6 adds the Day (green when its Assignment snapshot is fully checked in).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  goals        Goal[]
  pulses       Pulse[]
  days         Day[]
}

// A Goal is a single long-term pursuit. It lives dormant in the Vault (status
// `vault`) until activated (status `active`); activation arrives in a later
// slice. See CONTEXT.md.
enum GoalStatus {
  vault
  active
}

model Goal {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  status    GoalStatus @default(vault)
  // Priority rank among Active Goals (1 = highest). Null when in the Vault.
  // Ranks are contiguous: activating appends, deactivating compacts the rest.
  rank      Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tasks     Task[]

  @@index([userId])
}

// A Task is the atomic unit of work on a Goal. Each Task carries a Gear — an
// effort level from 1 (worst-day safety net) to 4 (best day). A Goal's "Gear N"
// is the pool of its Tasks tagged at that level. The 1–4 range is enforced in
// the app layer (see src/domain/gear.ts and src/lib/validation.ts). See
// CONTEXT.md.
model Task {
  id          String   @id @default(cuid())
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  description String
  gear        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([goalId])
}

// The user's self-reported Capacity for a Day, expressed as Good/Average/Bad/Worst.
// Stored as a plain string; the domain layer owns the type (see src/domain/capacity.ts).
// Per ADR-0002: at most one Pulse per Day; the Day settles on the final one.
model Pulse {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  capacity   String
  date       DateTime   @db.Date
  assignment Assignment?
  createdAt  DateTime   @default(now())

  @@unique([userId, date])
  @@index([userId])
}

// An Assignment is the bundle of Tasks produced by a Pulse. It is a frozen
// snapshot (ADR-0004): editing live Tasks never rewrites past Days.
model Assignment {
  id        String           @id @default(cuid())
  pulseId   String           @unique
  pulse     Pulse            @relation(fields: [pulseId], references: [id], onDelete: Cascade)
  items     AssignmentItem[]
  createdAt DateTime         @default(now())
}

// A single snapshotted Task within an Assignment. Captures description and Gear
// as of Pulse time — not a FK to the live Task row. See ADR-0004.
model AssignmentItem {
  id              String     @id @default(cuid())
  assignmentId    String
  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  goalId          String
  taskDescription String
  gear            Int
  completed       Boolean    @default(false)
  createdAt       DateTime   @default(now())

  @@index([assignmentId])
}

// The unit of success the system tracks. A Day is `green` once every item in
// its Assignment has been completed, otherwise `empty`. Created lazily on the
// first Check-in (the first time the user ticks an item) — taking a Pulse alone
// leaves no Day row. Its green status is derived from the Assignment snapshot,
// so past Days stay accurate even if the underlying Tasks change (ADR-0004).
enum DayStatus {
  green
  empty
}

model Day {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime  @db.Date
  status    DayStatus @default(empty)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, date])
  @@index([userId])
}
